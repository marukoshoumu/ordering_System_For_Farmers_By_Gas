# ========================================
# 配送伝票自動化ワーカー - 環境変数
# ========================================
# このファイルを .env にコピーして、実際の値を設定してください

# === サーバー設定 ===
PORT=3000
NODE_ENV=production

# === 認証 ===
# GASからのリクエスト認証用APIキー（ランダム文字列を生成して設定）
WORKER_API_KEY=your_worker_api_key_here

# === 表示モード ===
# false にするとブラウザが表示される（ローカル開発・セレクタ確認時に有用）
HEADLESS=true

# === ヤマト運輸 B2クラウド ===
YAMATO_LOGIN_URL=https://b2cloud.kuronekoyamato.co.jp/b2cloud/
YAMATO_LOGIN_ID=your_yamato_login_id
YAMATO_PASSWORD=your_yamato_password

# === 佐川急便 e飛伝Web ===
SAGAWA_LOGIN_URL=https://www.e-hidenweb2.sagawa-exp.co.jp/
SAGAWA_LOGIN_ID=your_sagawa_login_id
SAGAWA_PASSWORD=your_sagawa_password

# === Google Drive API ===
# サービスアカウントのJSONキーファイルへの絶対パス
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
# ヤマト伝票PDF保存先のGoogle DriveフォルダID
DRIVE_YAMATO_FOLDER_ID=your_yamato_drive_folder_id
# 佐川伝票PDF保存先のGoogle DriveフォルダID
DRIVE_SAGAWA_FOLDER_ID=your_sagawa_drive_folder_id

